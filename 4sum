import java.util.*;

class Solution {
    public List<List<Integer>> fourSum(int[] nums, int target) {
        int n = nums.length;
        // Use a Set to store unique quadruplets and prevent duplicates
        Set<List<Integer>> st = new HashSet<>();
        
        // Sorting helps in keeping the quadruplets in a consistent order
        Arrays.sort(nums);
        
        for (int i = 0; i < n; i++) {
            for (int j = i + 1; j < n; j++) {
                for (int k = j + 1; k < n; k++) {
                    for (int l = k + 1; l < n; l++) {
                        // Use long to prevent integer overflow
                        long sum = (long)nums[i] + nums[j] + nums[k] + nums[l];
                        
                        if (sum == target) {
                            List<Integer> quadruplet = Arrays.asList(nums[i], nums[j], nums[k], nums[l]);
                            st.add(quadruplet);
                        }
                    }
                }
            }
        }
        // Return the final list after all loops finish
        return new ArrayList<>(st);
    }
}

